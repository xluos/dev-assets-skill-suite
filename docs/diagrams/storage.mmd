flowchart TD
  ROOT["~/.dev-assets/repos/&lt;repo-key&gt;/"] --> SHARED["repo/<br/>共享层"]
  ROOT --> BRANCHES["branches/"]

  SHARED --> SM[manifest.json]
  SHARED --> SO["overview.md<br/>长期目标 + 约束"]
  SHARED --> SD["decisions.md<br/>跨分支通用决策"]
  SHARED --> SG["glossary.md<br/>共享入口 + 长期背景"]

  BRANCHES --> B1["&lt;branch_key&gt;/<br/>当前分支层"]
  BRANCHES --> ARCH["_archived/<br/>归档分支"]

  B1 --> BM["manifest.json<br/>含 setup_completed"]
  B1 --> BOV["overview.md<br/>冷启动摘要"]

  B1 --> BPR["progress.md<br/>当前进展 + 自动同步区"]:::snap
  B1 --> BRI["risks.md<br/>阻塞 + 注意点"]:::accum
  B1 --> BDE["decisions.md<br/>结论 + Why + 影响"]:::accum
  B1 --> BGL["glossary.md<br/>术语 + 链接"]:::accum

  B1 --> BUN["unsorted.md<br/>heuristic 兜底"]:::fallback
  B1 --> BPE["pending-promotion.md<br/>跨分支候选 staging"]:::staging

  B1 --> ART["artifacts/history/"]

  classDef snap fill:#e3f2fd,stroke:#1976d2
  classDef accum fill:#e8f5e9,stroke:#388e3c
  classDef fallback fill:#fce4ec,stroke:#c2185b
  classDef staging fill:#fffde7,stroke:#f57f17
