flowchart TD
  subgraph CONV["对话流"]
    SS[SessionStart hook]
    USER[用户诉求]
  end

  subgraph SUITE["dev-assets 套件（5 skill）"]
    ROUTER[using-dev-assets<br/>路由]
    CONTEXT[dev-assets-context<br/>读取 + tiered lookup]
    CAPTURE[dev-assets-capture<br/>统一写入]
    SETUP[dev-assets-setup<br/>unsorted 合并 promotion]
    GRAD[dev-assets-graduate<br/>分支归档]
  end

  subgraph MEM["~/.dev-assets/repos/"]
    BRANCH[branches/current<br/>分支层 v2 八件套]
    SHARED[repo/<br/>共享层]
    ARCH[branches/_archived<br/>归档层]
  end

  SS -.SessionStart.-> CONTEXT
  USER --> ROUTER
  ROUTER --> CONTEXT
  ROUTER --> CAPTURE
  ROUTER --> SETUP
  ROUTER --> GRAD

  CONTEXT -. 读 .-> BRANCH
  CONTEXT -. 读 .-> SHARED
  CAPTURE -. 写 .-> BRANCH
  SETUP -. 整理 .-> BRANCH
  GRAD -. 提炼到 .-> SHARED
  GRAD -. 搬迁到 .-> ARCH

  style SS fill:#e3f2fd
  style CAPTURE fill:#fff3e0
  style BRANCH fill:#e8f5e9
